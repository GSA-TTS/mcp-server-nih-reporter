{
  // OpenCode Configuration for SBX + USAi
  //
  // INSTRUCTIONS:
  // 1. Copy this file to your project root as `opencode.jsonc`
  // 2. Customize the models list based on your USAi API key entitlements
  // 3. Update the default model if needed
  // 4. Run with: sbx exec -it -e USAI_API_KEY="$USAI_API_KEY" -w $(pwd) SANDBOX opencode
  //
  // IMPORTANT: This file contains NO secrets.
  // API key is injected via USAI_API_KEY environment variable.

  "$schema": "https://opencode.ai/config.json",

  // Only enable USAi provider
  "enabled_providers": ["usai"],

  // Custom USAi provider using OpenAI-compatible SDK
  "provider": {
    "usai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "GSA USAi",
      "options": {
        "baseURL": "https://api.prod.gsai.mcaas.fcs.gsa.gov/api/v1",
        "apiKey": "{env:USAI_API_KEY}",
        "timeout": 600000,
        "chunkTimeout": 45000
      },
      "models": {
        // Claude models
        "claude_4_5_sonnet": {
          "name": "Claude 4.5 Sonnet",
          "limit": {
            "context": 200000,
            "output": 32768
          }
        },
        "claude_4_5_opus": {
          "name": "Claude 4.5 Opus",
          "limit": {
            "context": 200000,
            "output": 32768
          }
        },
        "claude_3_5_haiku": {
          "name": "Claude 3.5 Haiku",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        // Gemini models
        "gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash",
          "limit": {
            "context": 1048576,
            "output": 65536
          }
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro",
          "limit": {
            "context": 1048576,
            "output": 65536
          }
        },
        // OpenAI models
        "gpt-4o": {
          "name": "GPT-4o",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "gpt-4o-mini": {
          "name": "GPT-4o Mini",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        }
      }
    }
  },

  // Default model - change based on your preference/entitlements
  "model": "usai/claude_4_5_sonnet",

  // Load AGENTS.md for behavioral rules (if it exists)
  "instructions": ["AGENTS.md"],

  // Require approval for destructive operations
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "write": "ask"
  }
}
